{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["jest", "node"],
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "isolatedModules": true
  },
  "exclude": [
    "node_modules",
    "src/generated",
    "prisma.config.ts"
  ]
}