generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model order {
  id           String       @id @default(uuid())
  order_number Int          @unique
  status       order_status
  due_date     DateTime
  assigned_to  String?
  created_by   String
  assignedTo   employee?    @relation("AssignedOrders", fields: [assigned_to], references: [id])
  createdBy    employee     @relation("CreatedOrders", fields: [created_by], references: [id])
}

model employee {
  id              String        @id @default(uuid())
  login           String        @unique @db.VarChar(20)
  hashed_password String
  role            employee_role
  assignedOrders  order[]       @relation("AssignedOrders")
  createdOrders   order[]       @relation("CreatedOrders")
}

enum employee_role {
  printer
  cutter
  gluer
  admin
  technologist
}

enum order_status {
  printing
  cutting
  gluing
}
