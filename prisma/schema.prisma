// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model orders {
  id           String   @id @default(uuid())
  order_number Int      @unique
  status       order_status
  due_date     DateTime

  assigned_to  String?
  assignedTo   employees? @relation("AssignedOrders", fields: [assigned_to], references: [id])

  created_by   String
  createdBy    employees  @relation("CreatedOrders", fields: [created_by], references: [id])
}

model employees {
  id              String    @id @default(uuid())
  login           String    @unique @db.VarChar(20)
  hashed_password String
  role            employee_role

  assignedOrders  orders[]  @relation("AssignedOrders")
  createdOrders   orders[]  @relation("CreatedOrders")
}

enum employee_role {
  printer
  cutter
  gluer
  admin
  technologist
}

enum order_status {
  printing
  cutting
  gluing
}