generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model order {
  id           String       @id @default(uuid())
  order_number Int          @unique
  completed_steps String[]
  due_date     DateTime
  created_by   String
  createdBy    employee     @relation("CreatedOrders", fields: [created_by], references: [id])
  product_type product_type
}

model employee {
  id              String        @id @default(uuid())
  login           String        @unique @db.VarChar(20)
  hashed_password String
  role            employee_role
  createdOrders   order[]       @relation("CreatedOrders")
}

enum employee_role {
  printer_operator
  folding_operator
  sewing_operator
  case_maker
  hardcover_binder_operator
  perfect_bound_operator
  stitching_operator


  seller

  technologist
  admin
}

enum product_type {
  hardcover_book
  perfect_bound_book
  saddle_stitching
}
